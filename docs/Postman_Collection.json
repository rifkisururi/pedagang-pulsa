                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "X-Reference-Id",
                "value": "app-{{$guid}}",
                "description": "Unique reference ID for idempotency"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{product_id}}\",\n  \"destination\": \"08123456789\",\n  \"pin_session_token\": \"{{pin_session_token}}\"\n}",
              "options": {
