@model dynamic

@{
    ViewData["Title"] = "Supplier Balance Management";
    Layout = "_AdminLayout";
    var suppliers = ViewBag.Suppliers as List<PedagangPulsa.Domain.Entities.Supplier> ?? new List<PedagangPulsa.Domain.Entities.Supplier>();
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Supplier Balance Management</h1>
</div>

<!-- Supplier Balance Cards -->
<div class="row mb-4">
    @foreach (var supplier in suppliers)
    {
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                @supplier.Code
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800 mb-1">
                                Rp @(supplier.Balance?.ActiveBalance ?? 0).ToString("N0")
                            </div>
                            <div class="text-xs text-muted">@supplier.Name</div>
                        </div>
                        <div class="col-auto">
                            <button type="button" class="btn btn-sm btn-outline-primary"
                                    onclick="loadDepositModal(@supplier.Id)">
                                <i class="bi bi-plus-circle"></i> Deposit
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white py-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Search</label>
                <input type="text" class="form-control" id="searchInput" placeholder="Search by supplier name...">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Type</label>
                <select class="form-select" id="typeFilter">
                    <option value="">All Types</option>
                    <option value="Deposit">Deposit</option>
                    <option value="Transaction">Transaction</option>
                    <option value="Refund">Refund</option>
                    <option value="Adjustment">Adjustment</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Start Date</label>
                <input type="date" class="form-control" id="startDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">End Date</label>
                <input type="date" class="form-control" id="endDate" />
            </div>
            <div class="col-md-1">
                <label class="form-label small fw-bold">&nbsp;</label>
                <button type="button" class="btn btn-outline-secondary w-100" id="resetFilters">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </button>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped" id="ledgerTable" style="width: 100%;">
                <thead>
                    <tr>
                        <th>Date/Time</th>
                        <th>Supplier</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>Balance Before</th>
                        <th>Balance After</th>
                        <th>Description</th>
                        <th>Performed By</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />

    <script>
        $(document).ready(function() {
            var table = $('#ledgerTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/SupplierBalance/GetData',
                    type: 'POST',
                    data: function(d) {
                        d.search = $('#searchInput').val();
                        d.type = $('#typeFilter').val() || null;
                        d.startDate = $('#startDate').val() || null;
                        d.endDate = $('#endDate').val() || null;
                        return d;
                    }
                },
                order: [[0, 'desc']],
                columns: [
                    { data: 'createdAt' },
                    { data: 'supplierName' },
                    {
                        data: 'type',
                        render: function(data) {
                            var badgeClass = 'bg-secondary';
                            var label = data;

                            switch(data) {
                                case 'Deposit':
                                    badgeClass = 'bg-success';
                                    break;
                                case 'Transaction':
                                    badgeClass = 'bg-primary';
                                    break;
                                case 'Refund':
                                    badgeClass = 'bg-info';
                                    break;
                                case 'Adjustment':
                                    badgeClass = 'bg-warning';
                                    break;
                            }

                            return '<span class="badge ' + badgeClass + '">' + label + '</span>';
                        }
                    },
                    {
                        data: 'amount',
                        render: function(data, type, row) {
                            var color = data >= 0 ? 'text-success' : 'text-danger';
                            var sign = data >= 0 ? '+' : '';
                            return '<span class="' + color + '">' + sign + 'Rp ' + data.toLocaleString('id-ID') + '</span>';
                        }
                    },
                    {
                        data: 'balanceBefore',
                        render: function(data) {
                            return 'Rp ' + data.toLocaleString('id-ID');
                        }
                    },
                    {
                        data: 'balanceAfter',
                        render: function(data) {
                            return '<strong>Rp ' + data.toLocaleString('id-ID') + '</strong>';
                        }
                    },
                    { data: 'description' },
                    { data: 'performedBy' }
                ],
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]]
            });

            // Apply filters on change
            $('#searchInput, #typeFilter, #startDate, #endDate').on('change', function() {
                table.ajax.reload();
            });

            $('#searchInput').on('keyup', function(e) {
                if (e.key === 'Enter') {
                    table.ajax.reload();
                }
            });

            // Reset filters
            $('#resetFilters').on('click', function() {
                $('#searchInput').val('');
                $('#typeFilter').val('');
                $('#startDate').val('');
                $('#endDate').val('');
                table.ajax.reload();
            });
        });

        function  'Rp '.+toLocaleString('id-ID') {
            return 'Rp ' + amount.toLocaleString('id-ID');
        }

        function loadDepositModal(supplierId) {
            $.get('/SupplierBalance/Deposit/' + supplierId, function(data) {
                $('#depositModal .modal-content').html(data);
                $('#depositModal').modal('show');
            });
        }
    </script>
}

<!-- Deposit Modal -->
<div class="modal fade" id="depositModal" tabindex="-1">
    <div class="modal-dialog"></div>
</div>
