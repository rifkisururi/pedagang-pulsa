@model PedagangPulsa.Web.Areas.Admin.ViewModels.UserLevelDeleteViewModel

@{
    ViewData["Title"] = "Delete User Level";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Delete User Level</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Details
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-4">
                    <i class="bi bi-exclamation-triangle text-danger"></i>
                    Confirm Delete User Level
                </h5>

                <div class="mb-4">
                    <div class="alert alert-warning">
                        <strong>Are you sure you want to delete this user level?</strong><br />
                        This action cannot be undone. Make sure no users are assigned to this level before deleting.
                    </div>
                </div>

                <div class="mb-4">
                    <dl class="row">
                        <dt class="col-sm-4 text-muted">Level Name</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-primary">@Model.Name</span>
                        </dd>
                    </dl>
                </div>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete Level
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
