@model PedagangPulsa.Web.Areas.Admin.ViewModels.SupplierProductViewModel

@{
    ViewData["Title"] = "Add Supplier Mapping";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Add Supplier Mapping</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Mappings
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="alert alert-info">
                    <strong>Product:</strong> @Model.ProductCode - @Model.ProductName
                </div>

                <form asp-action="Add" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="SupplierId" class="form-label">Supplier <span class="text-danger">*</span></label>
                        <select asp-for="SupplierId" class="form-select" required>
                            <option value="">-- Select Supplier --</option>
                            @if (Model.AvailableSuppliers != null)
                            {
                                @foreach (var supplier in Model.AvailableSuppliers)
                                {
                                    <option value="@supplier.Id">@supplier.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="SupplierId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SupplierSku" class="form-label">Supplier SKU/Code</label>
                        <input asp-for="SupplierSku" class="form-control" placeholder="e.g., TSEL5" />
                        <div class="form-text">The product code used by this supplier</div>
                        <span asp-validation-for="SupplierSku" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CostPrice" class="form-label">Cost Price <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text">Rp</span>
                            <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0" required />
                        </div>
                        <span asp-validation-for="CostPrice" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sequence" class="form-label">Routing Sequence <span class="text-danger">*</span></label>
                        <input asp-for="Sequence" class="form-control" type="number" min="1" required />
                        <div class="form-text">
                            <i class="bi bi-info-circle"></i>
                            Suppliers will be tried in ascending sequence order (1, 2, 3...)
                        </div>
                        <span asp-validation-for="Sequence" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Add Supplier
                        </button>
                        <a asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
