@model PedagangPulsa.Web.Areas.Admin.ViewModels.SupplierProductListViewModel

@{
    ViewData["Title"] = "Supplier Mappings";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Supplier Mappings</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.ProductId" class="btn btn-outline-secondary me-2">
            <i class="bi bi-arrow-left"></i> Back to Product
        </a>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <a asp-action="Add" asp-route-productId="@Model.ProductId" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add Supplier
            </a>
        }
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam"></i> @Model.ProductCode - @Model.ProductName
        </h5>
        <small class="text-white-50">@Model.ProductCategory</small>
    </div>
    <div class="card-body">
        @if (Model.SupplierProducts.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover" id="supplierProductsTable">
                    <thead>
                        <tr>
                            <th style="width: 60px;">Seq</th>
                            <th>Supplier</th>
                            <th>Supplier SKU</th>
                            <th>Cost Price</th>
                            <th>Status</th>
                            <th class="text-end" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="sortableTable">
                        @foreach (var sp in Model.SupplierProducts.OrderBy(s => s.Sequence))
                        {
                            <tr data-supplier-id="@sp.SupplierId" data-sequence="@sp.Sequence">
                                <td>
                                    <span class="badge bg-primary fs-6 sequence-badge">@sp.Sequence</span>
                                </td>
                                <td>
                                    <a asp-controller="Supplier" asp-action="Details" asp-route-id="@sp.SupplierId" class="text-decoration-none">
                                        @sp.SupplierName
                                    </a>
                                </td>
                                <td>
                                    <code>@(string.IsNullOrEmpty(sp.SupplierSku) ? "-" : sp.SupplierSku)</code>
                                </td>
                                <td>
                                    <strong>@sp.CostPrice.ToString("N0")</strong>
                                </td>
                                <td>
                                    @if (sp.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group">
                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-productId="@Model.ProductId" asp-route-supplierId="@sp.SupplierId"
                                               class="btn btn-sm btn-outline-secondary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-productId="@Model.ProductId" asp-route-supplierId="@sp.SupplierId"
                                               class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="text-muted mt-3">No suppliers mapped to this product yet.</p>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <a asp-action="Add" asp-route-productId="@Model.ProductId" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Add First Supplier
                    </a>
                }
            </div>
        }
    </div>
</div>

@if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
{
    @section Scripts {
        <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>
        <script>
            $(document).ready(function() {
                $("#sortableTable").sortable({
                    items: "tr",
                    handle: ".sequence-badge",
                    axis: "y",
                    cursor: "move",
                    placeholder: "sortable-placeholder",
                    helper: function(e, ui) {
                        ui.children().each(function() {
                            $(this).width($(this).width());
                        });
                        return ui;
                    },
                    stop: function(event, ui) {
                        updateSequence();
                    }
                });

                function updateSequence() {
                    var suppliers = [];
                    $("#sortableTable tr").each(function(index) {
                        var supplierId = $(this).data("supplier-id");
                        suppliers.push({
                            supplierId: supplierId,
                            seq: index + 1
                        });
                        $(this).find(".sequence-badge").text(index + 1);
                    });

                    $.ajax({
                        url: '/SupplierProduct/Reorder',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({
                            productId: '@Model.ProductId',
                            suppliers: suppliers
                        }),
                        success: function(response) {
                            if (response.success) {
                                // Show success toast
                                console.log(response.message);
                            }
                        },
                        error: function() {
                            // Reload page on error
                            location.reload();
                        }
                    });
                }
            });
        </script>
        <style>
            .sortable-placeholder {
                background: #f0f0f0;
                border: 2px dashed #ccc;
                visibility: visible !important;
                height: 50px;
            }

            .sequence-badge {
                cursor: move;
            }
        </style>
    }
}
