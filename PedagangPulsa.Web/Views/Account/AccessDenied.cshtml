@{
    Layout = "_AdminLayout";
}

@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body text-center py-5">
                    <h1 class="display-1 text-danger">403</h1>
                    <h3 class="mb-3">Access Denied</h3>
                    <p class="text-muted">You don't have permission to access this resource.</p>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-house-door"></i> Back to Dashboard
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-secondary ms-2">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
