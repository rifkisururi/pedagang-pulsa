@using PedagangPulsa.Application.Services

@model DailyProfitReport

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Revenue</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">Rp @Model.TotalRevenue.ToString("N0")</div>
                    </div>
                    <div class="col-auto"><i class="bi bi-cash-stack fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Total Cost</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">Rp @Model.TotalCost.ToString("N0")</div>
                    </div>
                    <div class="col-auto"><i class="bi bi-cart-x fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Profit</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">Rp @Model.TotalProfit.ToString("N0")</div>
                    </div>
                    <div class="col-auto"><i class="bi bi-graph-up-arrow fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Profit Margin</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.ProfitMargin.ToString("F2")%</div>
                    </div>
                    <div class="col-auto"><i class="bi bi-percent fa-2x text-gray-300"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0"><i class="bi bi-box"></i> Top 10 Products by Profit</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Revenue</th>
                                <th class="text-end">Cost</th>
                                <th class="text-end">Profit</th>
                                <th class="text-center">Tx</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ByProduct.Take(10))
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-end">Rp @item.TotalRevenue.ToString("N0")</td>
                                    <td class="text-end">Rp @item.TotalCost.ToString("N0")</td>
                                    <td class="text-end text-success">Rp @item.TotalProfit.ToString("N0")</td>
                                    <td class="text-center">@item.TotalTransactions</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0"><i class="bi bi-truck"></i> Profit by Supplier</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Supplier</th>
                                <th class="text-end">Revenue</th>
                                <th class="text-end">Cost</th>
                                <th class="text-end">Profit</th>
                                <th class="text-center">Tx</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.BySupplier)
                            {
                                <tr>
                                    <td>@item.SupplierName</td>
                                    <td class="text-end">Rp @item.TotalRevenue.ToString("N0")</td>
                                    <td class="text-end">Rp @item.TotalCost.ToString("N0")</td>
                                    <td class="text-end text-success">Rp @item.TotalProfit.ToString("N0")</td>
                                    <td class="text-center">@item.TotalTransactions</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    string formatCurrency(decimal amount)
    {
        return "Rp " + amount.ToString("N0", new System.Globalization.CultureInfo("id-ID"));
    }
}
