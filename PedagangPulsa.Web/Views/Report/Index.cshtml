@model dynamic

@{
    ViewData["Title"] = "Profit Reports";
    Layout = "_AdminLayout";
    var today = DateTime.Today;
    var weekAgo = today.AddDays(-7);
    var monthStart = new DateTime(today.Year, today.Month, 1);
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Profit Reports</h1>
</div>

<!-- Report Tabs -->
<ul class="nav nav-tabs mb-4" id="reportTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="daily-tab" data-bs-toggle="tab" data-bs-target="#daily" type="button" role="tab">
            <i class="bi bi-calendar-day"></i> Daily Report
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button" role="tab">
            <i class="bi bi-graph-up"></i> Summary
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="supplier-tab" data-bs-toggle="tab" data-bs-target="#supplier" type="button" role="tab">
            <i class="bi bi-truck"></i> By Supplier
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="product-tab" data-bs-toggle="tab" data-bs-target="#product" type="button" role="tab">
            <i class="bi bi-box"></i> By Product
        </button>
    </li>
</ul>

<div class="tab-content" id="reportTabContent">
    <!-- Daily Report Tab -->
    <div class="tab-pane fade show active" id="daily" role="tabpanel">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Select Date</label>
                        <input type="date" class="form-control" id="dailyDate" value="@today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-auto">
                        <button type="button" class="btn btn-outline-primary" id="loadDailyReport">
                            <i class="bi bi-arrow-clockwise"></i> Load Report
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body" id="dailyReportContent">
                <div class="text-center text-muted py-5">
                    <i class="bi bi-calendar-day fs-1"></i>
                    <p class="mt-3">Select a date and click "Load Report" to view daily profit details</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Tab -->
    <div class="tab-pane fade" id="summary" role="tabpanel">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Start Date</label>
                        <input type="date" class="form-control" id="summaryStartDate" value="@weekAgo.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">End Date</label>
                        <input type="date" class="form-control" id="summaryEndDate" value="@today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-auto">
                        <button type="button" class="btn btn-outline-primary" id="loadSummaryReport">
                            <i class="bi bi-arrow-clockwise"></i> Load Summary
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <canvas id="summaryChart" style="max-height: 400px;"></canvas>
            </div>
        </div>
    </div>

    <!-- By Supplier Tab -->
    <div class="tab-pane fade" id="supplier" role="tabpanel">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Start Date</label>
                        <input type="date" class="form-control" id="supplierStartDate" value="@monthStart.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">End Date</label>
                        <input type="date" class="form-control" id="supplierEndDate" value="@today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-auto">
                        <button type="button" class="btn btn-outline-primary" id="loadSupplierReport">
                            <i class="bi bi-arrow-clockwise"></i> Load Report
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body" id="supplierReportContent">
                <div class="text-center text-muted py-5">
                    <i class="bi bi-truck fs-1"></i>
                    <p class="mt-3">Select date range and click "Load Report" to view profit by supplier</p>
                </div>
            </div>
        </div>
    </div>

    <!-- By Product Tab -->
    <div class="tab-pane fade" id="product" role="tabpanel">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">Start Date</label>
                        <input type="date" class="form-control" id="productStartDate" value="@monthStart.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-bold">End Date</label>
                        <input type="date" class="form-control" id="productEndDate" value="@today.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-auto">
                        <button type="button" class="btn btn-outline-primary" id="loadProductReport">
                            <i class="bi bi-arrow-clockwise"></i> Load Report
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body" id="productReportContent">
                <div class="text-center text-muted py-5">
                    <i class="bi bi-box fs-1"></i>
                    <p class="mt-3">Select date range and click "Load Report" to view profit by product</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let summaryChart = null;

        $(document).ready(function() {
            // Load daily report by default
            loadDailyReport();

            // Load summary when tab is shown
            $('#summary-tab').on('shown.bs.tab', function() {
                loadSummaryReport();
            });
        });

        // Daily Report
        $('#loadDailyReport').on('click', loadDailyReport);

        function loadDailyReport() {
            const date = $('#dailyDate').val();
            if (!date) return;

            $('#dailyReportContent').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');

            $.ajax({
                url: '/Report/Daily',
                type: 'POST',
                data: { date: date },
                success: function(data) {
                    $('#dailyReportContent').html(data);
                },
                error: function() {
                    $('#dailyReportContent').html('<div class="alert alert-danger">Error loading report</div>');
                }
            });
        }

        // Summary Report
        $('#loadSummaryReport').on('click', loadSummaryReport);

        function loadSummaryReport() {
            const startDate = $('#summaryStartDate').val();
            const endDate = $('#summaryEndDate').val();
            if (!startDate || !endDate) return;

            $.ajax({
                url: '/Report/SummaryData',
                type: 'POST',
                data: { startDate: startDate, endDate: endDate },
                success: function(response) {
                    if (response.success) {
                        renderSummaryChart(response.data);
                    }
                },
                error: function() {
                    toastr.error('Error loading summary');
                }
            });
        }

        function renderSummaryChart(data) {
            const labels = data.map(d => {
                const date = new Date(d.date);
                return date.toLocaleDateString('id-ID', { day: '2-digit', month: 'short' });
            });
            const profitData = data.map(d => d.totalProfit);
            const revenueData = data.map(d => d.totalRevenue);
            const costData = data.map(d => d.totalCost);

            if (summaryChart) {
                summaryChart.destroy();
            }

            const ctx = document.getElementById('summaryChart').getContext('2d');
            summaryChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Revenue',
                            data: revenueData,
                            borderColor: 'rgba(54, 162, 235, 1)',
                            backgroundColor: 'rgba(54, 162, 235, 0.1)',
                            tension: 0.1
                        },
                        {
                            label: 'Cost',
                            data: costData,
                            borderColor: 'rgba(255, 99, 132, 1)',
                            backgroundColor: 'rgba(255, 99, 132, 0.1)',
                            tension: 0.1
                        },
                        {
                            label: 'Profit',
                            data: profitData,
                            borderColor: 'rgba(75, 192, 192, 1)',
                            backgroundColor: 'rgba(75, 192, 192, 0.1)',
                            tension: 0.1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'top' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': Rp ' + context.parsed.y.toLocaleString('id-ID');
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: function(value) {
                                    return 'Rp ' + value.toLocaleString('id-ID');
                                }
                            }
                        }
                    }
                }
            });
        }

        // Supplier Report
        $('#loadSupplierReport').on('click', loadSupplierReport);

        function loadSupplierReport() {
            const startDate = $('#supplierStartDate').val();
            const endDate = $('#supplierEndDate').val();

            $('#supplierReportContent').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');

            $.ajax({
                url: '/Report/BySupplier',
                type: 'POST',
                data: { startDate: startDate || null, endDate: endDate || null },
                success: function(data) {
                    $('#supplierReportContent').html(data);
                },
                error: function() {
                    $('#supplierReportContent').html('<div class="alert alert-danger">Error loading report</div>');
                }
            });
        }

        // Product Report
        $('#loadProductReport').on('click', loadProductReport);

        function loadProductReport() {
            const startDate = $('#productStartDate').val();
            const endDate = $('#productEndDate').val();

            $('#productReportContent').html('<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>');

            $.ajax({
                url: '/Report/ByProduct',
                type: 'POST',
                data: { startDate: startDate || null, endDate: endDate || null },
                success: function(data) {
                    $('#productReportContent').html(data);
                },
                error: function() {
                    $('#productReportContent').html('<div class="alert alert-danger">Error loading report</div>');
                }
            });
        }
    </script>
}
