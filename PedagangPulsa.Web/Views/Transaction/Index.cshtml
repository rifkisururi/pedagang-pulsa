@model dynamic

@{
    ViewData["Title"] = "Transactions";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Transactions</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-white py-3">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold">Search</label>
                <input type="text" class="form-control" id="searchInput" placeholder="Search by destination, SN...">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Status</label>
                <select class="form-select" id="statusFilter">
                    <option value="">All Status</option>
                    <option value="pending">Pending</option>
                    <option value="processing">Processing</option>
                    <option value="success">Success</option>
                    <option value="failed">Failed</option>
                    <option value="cancelled">Cancelled</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">Start Date</label>
                <input type="date" class="form-control" id="startDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold">End Date</label>
                <input type="date" class="form-control" id="endDate" />
            </div>
            <div class="col-md-1">
                <label class="form-label small fw-bold">&nbsp;</label>
                <button type="button" class="btn btn-outline-secondary w-100" id="resetFilters">
                    <i class="bi bi-arrow-clockwise"></i> Reset
                </button>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover table-striped" id="transactionsTable" style="width: 100%;">
                <thead>
                    <tr>
                        <th>Reference ID</th>
                        <th>Date/Time</th>
                        <th>Username</th>
                        <th>Product</th>
                        <th>Destination</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Supplier</th>
                        <th>Actions</th>
                    </tr>
                </thead>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />

    <script>
        $(document).ready(function() {
            var table = $('#transactionsTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '/Transaction/GetData',
                    type: 'POST',
                    data: function(d) {
                        d.search = $('#searchInput').val();
                        d.status = $('#statusFilter').val() || null;
                        d.startDate = $('#startDate').val() || null;
                        d.endDate = $('#endDate').val() || null;
                        return d;
                    }
                },
                order: [[1, 'desc']],
                columns: [
                    {
                        data: 'referenceId',
                        render: function(data, type, row) {
                            const shortId = data.substring(0, 8);
                            return '<a href="/Transaction/Details/' + row.id + '" class="text-decoration-none">' +
                                '<code>' + shortId + '</code></a>';
                        }
                    },
                    { data: 'createdAt' },
                    { data: 'username' },
                    { data: 'productName' },
                    { data: 'destination' },
                    {
                        data: 'sellPrice',
                        render: function(data) {
                            return data != null ? 'Rp ' + data.toLocaleString('id-ID') : '-';
                        }
                    },
                    {
                        data: 'status',
                        render: function(data) {
                            var badgeClass = 'bg-secondary';
                            var icon = '';
                            switch(data.toLowerCase()) {
                                case 'success':
                                    badgeClass = 'bg-success';
                                    icon = '<i class="bi bi-check-circle"></i> ';
                                    break;
                                case 'failed':
                                    badgeClass = 'bg-danger';
                                    icon = '<i class="bi bi-x-circle"></i> ';
                                    break;
                                case 'pending':
                                case 'processing':
                                    badgeClass = 'bg-warning';
                                    icon = '<i class="bi bi-clock"></i> ';
                                    break;
                                case 'cancelled':
                                    badgeClass = 'bg-secondary';
                                    icon = '<i class="bi bi-ban"></i> ';
                                    break;
                            }
                            return '<span class="badge ' + badgeClass + '">' + icon + data + '</span>';
                        }
                    },
                    { data: 'supplierName' },
                    {
                        data: null,
                        orderable: false,
                        render: function(data, type, row) {
                            return '<a href="/Transaction/Details/' + row.id + '" class="btn btn-sm btn-outline-primary" title="View"><i class="bi bi-eye"></i></a>';
                        }
                    }
                ],
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]]
            });

            // Apply filters on change
            $('#searchInput, #statusFilter, #startDate, #endDate').on('change', function() {
                table.ajax.reload();
            });

            $('#searchInput').on('keyup', function(e) {
                if (e.key === 'Enter') {
                    table.ajax.reload();
                }
            });

            // Reset filters
            $('#resetFilters').on('click', function() {
                $('#searchInput').val('');
                $('#statusFilter').val('');
                $('#startDate').val('');
                $('#endDate').val('');
                table.ajax.reload();
            });
        });
    </script>
}
