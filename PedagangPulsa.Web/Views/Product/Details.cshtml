@model PedagangPulsa.Web.Areas.Admin.ViewModels.ProductDetailViewModel

@{
    ViewData["Title"] = "Product Details";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Product Details</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
            <i class="bi bi-pencil"></i> Edit Product
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Basic Information</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <th style="width: 35%;">Product Code</th>
                        <td><span class="fw-bold">@Model.Code</span></td>
                    </tr>
                    <tr>
                        <th>Operator</th>
                        <td>@(string.IsNullOrEmpty(Model.Operator) ? "-" : Model.Operator)</td>
                    </tr>
                    <tr>
                        <th>Product Name</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Category</th>
                        <td>@Model.CategoryName</td>
                    </tr>
                    <tr>
                        <th>Denomination</th>
                        <td>@(Model.Denomination.HasValue ? Model.Denomination.Value.ToString("N0") : "-")</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Price per Level</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Level</th>
                                <th class="text-end">Sell Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var price in Model.LevelPrices)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@price.LevelName</span>
                                    </td>
                                    <td class="text-end fw-bold">Rp @price.SellPrice.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
