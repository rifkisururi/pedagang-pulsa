@model PedagangPulsa.Web.Areas.Admin.ViewModels.ProductDetailViewModel

@{
    ViewData["Title"] = "Product Details";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Product Details</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <!-- Product Info Card -->
    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="card-title mb-0"><i class="bi bi-box-seam"></i> Product Info</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-5 text-muted">Code</dt>
                    <dd class="col-sm-7"><code>@Model.Code</code></dd>

                    <dt class="col-sm-5 text-muted">Name</dt>
                    <dd class="col-sm-7">@Model.Name</dd>

                    <dt class="col-sm-5 text-muted">Category</dt>
                    <dd class="col-sm-7">@Model.CategoryName</dd>

                    <dt class="col-sm-5 text-muted">Denomination</dt>
                    <dd class="col-sm-7">Rp @(Model.Denomination?.ToString("N0") ?? "0")</dd>

                    <dt class="col-sm-5 text-muted">Status</dt>
                    <dd class="col-sm-7">
                        <span class="badge @(Model.IsActive ? "bg-success" : "bg-secondary")">
                            @(Model.IsActive ? "Active" : "Inactive")
                        </span>
                    </dd>

                    <dt class="col-sm-5 text-muted">Description</dt>
                    <dd class="col-sm-7 small text-muted">@(Model.Description ?? "-")</dd>
                </dl>
            </div>
            <div class="card-footer">
                <div class="d-flex gap-2">
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                            <i class="bi bi-pencil"></i> Edit Product
                        </a>
                    }
                    <a asp-controller="SupplierProduct" asp-action="Index" asp-route-productId="@Model.Id" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-shop"></i> Suppliers
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Price Management Card -->
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="bi bi-tags"></i> Price per Level</h5>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <small class="text-muted"><i class="bi bi-info-circle"></i> Click price to edit</small>
                }
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Level</th>
                                <th>Sell Price</th>
                                <th>Margin</th>
                                <th>Margin %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var price in Model.LevelPrices)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@price.LevelName</span>
                                    </td>
                                    <td>
                                        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                        {
                                            <div class="price-edit" data-product-id="@Model.Id" data-level-id="@price.LevelId">
                                                <span class="price-display">Rp @price.SellPrice.ToString("N0")</span>
                                                <input type="number" class="form-control form-control-sm price-input d-none"
                                                       value="@price.SellPrice" step="0.01" min="0"
                                                       data-cost-price="0" />
                                            </div>
                                        }
                                        else
                                        {
                                            <span>Rp @price.SellPrice.ToString("N0")</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="@(price.Margin < 0 ? "text-danger" : "text-success")">
                                            Rp @price.Margin.ToString("N0")
                                        </span>
                                    </td>
                                    <td>
                                        <span class="@(price.MarginPercent < 0 ? "text-danger" : "text-success")">
                                            @price.MarginPercent.ToString("F2")%
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="alert alert-info small">
                    <i class="bi bi-info-circle"></i>
                    <strong>Base Price:</strong> Rp @Model.Denomination?.ToString("N0") ?? "0" |
                    Set sell price for each user level. Prices below cost price will be highlighted in <span class="text-danger">red</span>.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Inline price editing
            $('.price-edit').on('click', function() {
                const container = $(this);
                const display = container.find('.price-display');
                const input = container.find('.price-input');

                if (input.hasClass('d-none')) {
                    display.addClass('d-none');
                    input.removeClass('d-none').focus();
                }
            });

            $('.price-input').on('blur', function() {
                const input = $(this);
                const container = input.closest('.price-edit');
                const display = container.find('.price-display');
                const productId = container.data('product-id');
                const levelId = container.data('level-id');
                const newPrice = parseFloat(input.val());
                const costPrice = parseFloat(input.data('cost-price'));

                // Update UI immediately
                const formattedPrice = 'Rp ' + newPrice.toLocaleString('id-ID');
                display.text(formattedPrice);
                display.removeClass('d-none');
                input.addClass('d-none');

                // Update margin display
                const row = container.closest('tr');
                const margin = newPrice - costPrice;
                const marginPercent = costPrice > 0 ? (margin / costPrice * 100) : 0;

                row.find('td:nth-child(3) span')
                    .text(formattedPrice)
                    .removeClass('text-danger text-success')
                    .addClass(margin < 0 ? 'text-danger' : 'text-success');

                row.find('td:nth-child(4) span')
                    .text(marginPercent.toFixed(2) + '%')
                    .removeClass('text-danger text-success')
                    .addClass(marginPercent < 0 ? 'text-danger' : 'text-success');

                // Send AJAX request to update price
                $.ajax({
                    url: '/Product/UpdatePrice',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        productId: productId,
                        levelId: levelId,
                        sellPrice: newPrice
                    }),
                    success: function(response) {
                        if (response.success) {
                            // Show success message
                            showAlert('success', response.message);
                        } else {
                            showAlert('danger', response.message);
                        }
                    },
                    error: function() {
                        showAlert('danger', 'Failed to update price');
                    }
                });
            });

            $('.price-input').on('keypress', function(e) {
                if (e.which === 13) { // Enter key
                    $(this).blur();
                }
            });

            function showAlert(type, message) {
                const alertHtml = '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    message +
                    '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                    '</div>';
                $('.container-fluid').prepend(alertHtml);
                setTimeout(function() {
                    $('.alert').fadeOut();
                }, 3000);
            }
        });

        function  'Rp '.+toLocaleString('id-ID') {
            return 'Rp ' + amount.toLocaleString('id-ID');
        }
    </script>
}
