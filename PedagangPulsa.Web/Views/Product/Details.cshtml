@model PedagangPulsa.Web.Areas.Admin.ViewModels.ProductDetailViewModel

@{
    ViewData["Title"] = "Product Details";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Product Details</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary me-2">
            <i class="bi bi-pencil"></i> Edit Product
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-5">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Basic Information</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm table-borderless mb-0">
                    <tr>
                        <th style="width: 35%;">Product Code</th>
                        <td><span class="fw-bold">@Model.Code</span></td>
                    </tr>
                    <tr>
                        <th>Product Name</th>
                        <td>@Model.Name</td>
                    </tr>
                    <tr>
                        <th>Operator</th>
                        <td>@(string.IsNullOrEmpty(Model.Operator) ? "-" : Model.Operator)</td>
                    </tr>
                    <tr>
                        <th>Category</th>
                        <td><span class="badge bg-info">@Model.CategoryName</span></td>
                    </tr>
                    <tr>
                        <th>Product Group</th>
                        <td>@(!string.IsNullOrEmpty(Model.ProductGroupName) ? Model.ProductGroupName : "<span class=\"text-muted\">-</span>")</td>
                    </tr>
                    <tr>
                        <th>Denomination</th>
                        <td>@(Model.Denomination.HasValue ? "Rp " + Model.Denomination.Value.ToString("N0") : "-")</td>
                    </tr>
                    <tr>
                        <th>Masa Aktif</th>
                        <td>@(!string.IsNullOrEmpty(Model.ValidityText) ? Model.ValidityText : (Model.ValidityDays.HasValue ? Model.ValidityDays.Value + " Hari" : "-"))</td>
                    </tr>
                    <tr>
                        <th>Kuota</th>
                        <td>@(!string.IsNullOrEmpty(Model.QuotaText) ? Model.QuotaText : (Model.QuotaMb.HasValue ? Model.QuotaMb.Value.ToString("N0") + " MB" : "-"))</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            @if (Model.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactive</span>
                            }
                        </td>
                    <tr>
                        <th>Description</th>
                        <td>@(string.IsNullOrEmpty(Model.Description) ? "-" : Model.Description)</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-white">
                <h5 class="card-title mb-0">Margin per Level</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Level</th>
                                <th class="text-end">Cost Price</th>
                                <th class="text-end">Margin</th>
                                <th class="text-end">Margin %</th>
                                <th class="text-end">Sell Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var price in Model.LevelPrices)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-primary">@price.LevelName</span>
                                    </td>
                                    <td class="text-end">Rp @price.CostPrice.ToString("N0")</td>
                                    <td class="text-end text-primary">Rp @price.Margin.ToString("N0")</td>
                                    <td class="text-end text-muted">@price.MarginPercent.ToString("F1")%</td>
                                    <td class="text-end fw-bold">Rp @price.ComputedSellPrice.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.SupplierProducts.Any())
{
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">Supplier Products</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Supplier</th>
                                    <th>Supplier Code</th>
                                    <th>Supplier Name</th>
                                    <th class="text-end">Cost Price</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sp in Model.SupplierProducts)
                                {
                                    <tr>
                                        <td>@sp.Seq</td>
                                        <td><span class="badge bg-secondary">@sp.SupplierName</span></td>
                                        <td><code>@sp.SupplierProductCode</code></td>
                                        <td>@(sp.SupplierProductName ?? "-")</td>
                                        <td class="text-end fw-bold">Rp @sp.CostPrice.ToString("N0")</td>
                                        <td>
                                            @if (sp.IsActive)
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
