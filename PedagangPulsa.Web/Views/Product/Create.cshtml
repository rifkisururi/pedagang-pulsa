@model PedagangPulsa.Web.Areas.Admin.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Create Product";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Create Product</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <h5 class="mb-3">Basic Information</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label">Product Code <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" placeholder="e.g., TSEL10" required />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Operator" class="form-label">Operator</label>
                            <input asp-for="Operator" class="form-control" placeholder="e.g., Telkomsel" />
                            <span asp-validation-for="Operator" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Name" class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Telkomsel 10.000" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                @if (Model.AvailableCategories != null)
                                {
                                    @foreach (var cat in Model.AvailableCategories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Denomination" class="form-label">Denomination</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="Denomination" class="form-control" type="number" step="1" min="0" />
                            </div>
                            <span asp-validation-for="Denomination" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Product description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">Margin per Level</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-striped" id="levelPricesTable">
                            <thead>
                                <tr>
                                    <th>Level</th>
                                    <th>Margin (Rp)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AvailableLevels != null)
                                {
                                    @for (int i = 0; i < Model.AvailableLevels.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <span class="badge bg-primary">@Model.AvailableLevels[i].Name</span>
                                                <input type="hidden" name="LevelPrices[@i].LevelId" value="@Model.AvailableLevels[i].Id" />
                                            </td>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text">Rp</span>
                                                    <input type="number" name="LevelPrices[@i].Margin" class="form-control form-control-sm"
                                                           step="0.01" min="0" value="200" />
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            Set margin for each user level. Sell Price = Cost Price + Margin.
                        </small>
                    </div>

                    <h5 class="mb-3">Settings</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Create Product
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
