@model PedagangPulsa.Web.Areas.Admin.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Edit Product</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-2">
            <i class="bi bi-info-circle"></i> View Details
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <h5 class="mb-3">Basic Information</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label">Product Code <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" placeholder="e.g., TSEL10" required />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Operator" class="form-label">Operator</label>
                            <input asp-for="Operator" class="form-control" placeholder="e.g., Telkomsel" />
                            <span asp-validation-for="Operator" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Name" class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Telkomsel 10.000" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select" id="categoryId" required>
                                <option value="">-- Select Category --</option>
                                @if (Model.AvailableCategories != null)
                                {
                                    @foreach (var cat in Model.AvailableCategories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ProductGroupId" class="form-label">Product Group</label>
                            <select asp-for="ProductGroupId" class="form-select" id="groupId">
                                <option value="">-- Select Group --</option>
                                @if (Model.AvailableGroups != null)
                                {
                                    @foreach (var grp in Model.AvailableGroups)
                                    {
                                        <option value="@grp.Id" data-category="@grp.CategoryId">@grp.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ProductGroupId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Denomination" class="form-label">Denomination</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="Denomination" class="form-control" type="number" step="1" min="0" />
                            </div>
                            <span asp-validation-for="Denomination" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="ValidityDays" class="form-label">Masa Aktif (Hari)</label>
                            <div class="input-group">
                                <input asp-for="ValidityDays" class="form-control" type="number" min="1" placeholder="30" />
                                <span class="input-group-text">Hari</span>
                            </div>
                            <span asp-validation-for="ValidityDays" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="ValidityText" class="form-label">Teks Masa Aktif</label>
                            <input asp-for="ValidityText" class="form-control" placeholder="e.g., 30 Hari" />
                            <span asp-validation-for="ValidityText" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="QuotaMb" class="form-label">Kuota</label>
                            <div class="input-group">
                                <input id="quotaInput" type="number" min="0" step="any" class="form-control" placeholder="5" />
                                <select id="quotaUnit" class="form-select" style="max-width: 80px;">
                                    <option value="GB">GB</option>
                                    <option value="MB">MB</option>
                                </select>
                            </div>
                            <input asp-for="QuotaMb" type="hidden" id="quotaMbHidden" />
                            <span class="text-muted small" id="quotaPreview"></span>
                            <span asp-validation-for="QuotaMb" class="text-danger small"></span>
                        </div>
                        <div class="col-md-3">
                            <label asp-for="QuotaText" class="form-label">Teks Kuota</label>
                            <input asp-for="QuotaText" class="form-control" placeholder="e.g., 5 GB" />
                            <span asp-validation-for="QuotaText" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2" placeholder="Product description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">Margin per Level</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-striped" id="levelPricesTable">
                            <thead>
                                <tr>
                                    <th>Level</th>
                                    <th>Margin (Rp)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LevelPrices != null && Model.AvailableLevels != null)
                                {
                                    @for (int i = 0; i < Model.LevelPrices.Count; i++)
                                    {
                                        var level = Model.AvailableLevels.FirstOrDefault(l => l.Id == Model.LevelPrices[i].LevelId);
                                        <tr>
                                            <td>
                                                <span class="badge bg-primary">@(level?.Name ?? "Unknown")</span>
                                                <input type="hidden" name="LevelPrices[@i].LevelId" value="@Model.LevelPrices[i].LevelId" />
                                            </td>
                                            <td>
                                                <div class="input-group input-group-sm">
                                                    <span class="input-group-text">Rp</span>
                                                    <input type="number" name="LevelPrices[@i].Margin" class="form-control form-control-sm"
                                                           step="0.01" min="0" value="@Model.LevelPrices[i].Margin" />
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            Set margin for each user level. Sell Price = Cost Price + Margin.
                        </small>
                    </div>

                    <h5 class="mb-3">Settings</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        var allGroups = @Html.Raw(Json.Serialize(Model.AvailableGroups ?? new List<PedagangPulsa.Web.Areas.Admin.ViewModels.ProductViewModel.GroupItem>()));

        function filterGroups(categoryId) {
            var $groupSelect = $('#groupId');
            var currentVal = $groupSelect.val();
            $groupSelect.find('option:not(:first)').remove();

            var filtered = categoryId
                ? allGroups.filter(function(g) { return g.categoryId === parseInt(categoryId); })
                : allGroups;

            filtered.forEach(function(g) {
                $groupSelect.append('<option value="' + g.id + '">' + g.name + '</option>');
            });

            // Restore selection if still valid
            if (currentVal && filtered.some(function(g) { return g.id === parseInt(currentVal); })) {
                $groupSelect.val(currentVal);
            }
        }

        $('#categoryId').on('change', function() {
            filterGroups($(this).val());
        });

        // Initial filter based on current category
        $(document).ready(function() {
            var catId = $('#categoryId').val();
            if (catId) filterGroups(catId);

            // Populate quota input from existing QuotaMb value
            var quotaMb = parseInt($('#quotaMbHidden').val()) || 0;
            if (quotaMb > 0 && quotaMb % 1024 === 0) {
                $('#quotaInput').val(quotaMb / 1024);
                $('#quotaUnit').val('GB');
            } else if (quotaMb > 0) {
                $('#quotaInput').val(quotaMb);
                $('#quotaUnit').val('MB');
            }
            updateQuotaPreview();
        });

        function updateQuotaPreview() {
            var val = parseFloat($('#quotaInput').val()) || 0;
            var unit = $('#quotaUnit').val();
            var mb = unit === 'GB' ? Math.round(val * 1024) : Math.round(val);
            $('#quotaMbHidden').val(mb > 0 ? mb : '');

            if (val > 0) {
                var display = unit === 'GB' ? val + ' GB = ' + mb.toLocaleString('id-ID') + ' MB' : mb.toLocaleString('id-ID') + ' MB';
                $('#quotaPreview').text('= ' + display);
            } else {
                $('#quotaPreview').text('');
            }
        }

        $('#quotaInput, #quotaUnit').on('input change', updateQuotaPreview);
    </script>
}
