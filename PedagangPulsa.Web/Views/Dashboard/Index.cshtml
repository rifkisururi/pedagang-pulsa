@using PedagangPulsa.Web.Areas.Admin.ViewModels
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

@functions {
    static string FormatCurrency(decimal amount)
    {
        if (amount >= 1_000_000_000m) return $"Rp {amount / 1_000_000_000m:F1}B";
        if (amount >= 1_000_000m) return $"Rp {amount / 1_000_000m:F1}M";
        if (amount >= 1_000m) return $"Rp {amount / 1_000m:F1}K";
        return $"Rp {amount:N0}";
    }

    static string FormatPercent(double value)
    {
        return $"{value:F1}%";
    }

    static string TrendIcon(double vsYesterday)
    {
        if (vsYesterday > 0) return $"<span class=\"text-success\"><i class=\"bi bi-arrow-up\"></i> {FormatPercent(vsYesterday)}</span>";
        if (vsYesterday < 0) return $"<span class=\"text-danger\"><i class=\"bi bi-arrow-down\"></i> {FormatPercent(Math.Abs(vsYesterday))}</span>";
        return "<span class=\"text-muted\">0%</span>";
    }
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary">Share</button>
            <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle">
            <i class="bi bi-calendar3"></i>
            Today
        </button>
    </div>
</div>

<!-- KPI Cards Row 1 -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-cart-check text-primary fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Transactions Today</h6>
                        <h4 class="mb-0 fw-bold">@Model.TotalTransactionsToday.ToString("N0")</h4>
                        <p class="mb-0 small">
                            @Html.Raw(TrendIcon(Model.TransactionsVsYesterday))
                            <span class="text-muted">vs yesterday</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-currency-dollar text-success fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Revenue Today</h6>
                        <h4 class="mb-0 fw-bold">@FormatCurrency(Model.RevenueToday)</h4>
                        <p class="mb-0 small">
                            @Html.Raw(TrendIcon((double)Model.RevenueVsYesterday))
                            <span class="text-muted">vs yesterday</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-graph-up-arrow text-info fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Profit Today</h6>
                        <h4 class="mb-0 fw-bold">@FormatCurrency(Model.ProfitToday)</h4>
                        <p class="mb-0 small">
                            <span class="@(Model.ProfitVsYesterday >= 0 ? "text-success" : "text-danger")">@FormatPercent((double)Model.ProfitMargin)</span>
                            <span class="text-muted">margin</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Failed Transactions</h6>
                        <h4 class="mb-0 fw-bold">@Model.FailedTransactions.ToString("N0")</h4>
                        <p class="mb-0 small">
                            <span class="text-danger">@FormatPercent(Model.FailedRate)</span>
                            <span class="text-muted">of total</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- KPI Cards Row 2 -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-secondary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-people text-secondary fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Active Users</h6>
                        <h4 class="mb-0 fw-bold">@Model.ActiveUsers.ToString("N0")</h4>
                        <p class="mb-0 small">
                            <span class="text-success"><i class="bi bi-arrow-up"></i> @Model.NewUsersThisWeek</span>
                            <span class="text-muted">this week</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-person-plus text-warning fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">New Users Today</h6>
                        <h4 class="mb-0 fw-bold">@Model.NewUsersToday.ToString("N0")</h4>
                        <p class="mb-0 small">
                            @Html.Raw(TrendIcon(Model.NewUsersVsYesterday))
                            <span class="text-muted">vs yesterday</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-clock-history text-primary fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Pending Topup</h6>
                        <h4 class="mb-0 fw-bold">@Model.PendingTopupCount.ToString("N0")</h4>
                        <p class="mb-0 small">
                            <span class="text-primary">@FormatCurrency(Model.PendingTopupAmount)</span>
                            <span class="text-muted">total</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex align-items-center">
                    <div class="flex-shrink-0">
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-wallet2 text-success fs-4"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="text-muted mb-1 text-uppercase small fw-bold">Total User Balance</h6>
                        <h4 class="mb-0 fw-bold">@FormatCurrency(Model.TotalUserBalance)</h4>
                        <p class="mb-0 small">
                            <span class="text-muted">across all users</span>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <!-- Transactions per Hour Chart -->
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="card-title mb-0">Transactions per Hour</h5>
            </div>
            <div class="card-body">
                <canvas id="transactionChart" style="max-height: 350px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Supplier Status Widget -->
    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="card-title mb-0">Supplier Status</h5>
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-3">
                    @if (Model.SupplierStatuses.Any())
                    {
                        foreach (var supplier in Model.SupplierStatuses)
                        {
                            var balanceClass = supplier.ActiveBalance switch
                            {
                                >= 5_000_000m => "bg-success bg-opacity-10",
                                >= 500_000m => "bg-warning bg-opacity-10",
                                _ => "bg-danger bg-opacity-10"
                            };
                            var badgeClass = supplier.ActiveBalance switch
                            {
                                >= 5_000_000m => "bg-success",
                                >= 500_000m => "bg-warning",
                                _ => "bg-danger"
                            };
                            var statusIcon = supplier.IsActive ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger";

                            <div class="d-flex justify-content-between align-items-center p-2 @balanceClass rounded">
                                <span class="fw-bold">
                                    <i class="bi @statusIcon me-1"></i>
                                    @supplier.Name
                                </span>
                                <span class="badge @badgeClass">@FormatCurrency(supplier.ActiveBalance)</span>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted text-center mb-0">No active suppliers found</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Revenue Chart -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="card-title mb-0">Revenue Last 7 Days</h5>
            </div>
            <div class="card-body">
                <canvas id="revenueChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        // Transactions per Hour Chart
        const transactionCtx = document.getElementById('transactionChart').getContext('2d');
        new Chart(transactionCtx, {
            type: 'line',
            data: {
                labels: ['00:00', '01:00', '02:00', '03:00', '04:00', '05:00', '06:00', '07:00', '08:00', '09:00', '10:00', '11:00', '12:00', '13:00', '14:00', '15:00', '16:00', '17:00', '18:00', '19:00', '20:00', '21:00', '22:00', '23:00'],
                datasets: [{
                    label: 'Today',
                    data: @Json.Serialize(Model.HourlyTransactionsToday),
                    borderColor: 'rgb(102, 126, 234)',
                    backgroundColor: 'rgba(102, 126, 234, 0.1)',
                    tension: 0.4,
                    fill: true
                }, {
                    label: 'Yesterday',
                    data: @Json.Serialize(Model.HourlyTransactionsYesterday),
                    borderColor: 'rgb(118, 75, 162)',
                    backgroundColor: 'rgba(118, 75, 162, 0.1)',
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });

        // Revenue Chart
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        const revenueLabels = @Json.Serialize(Model.DailyRevenueItems.Select(r => r.Label));
        const revenueFullDates = @Json.Serialize(Model.DailyRevenueItems.Select(r => r.FullDate));
        const revenueData = @Json.Serialize(Model.DailyRevenueItems.Select(r => Math.Round(r.Revenue / 1_000_000m, 1)));

        new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: revenueFullDates,
                datasets: [{
                    label: 'Revenue (Millions)',
                    data: revenueData,
                    backgroundColor: revenueData.map((_, i) => i % 2 === 0 ? 'rgba(102, 126, 234, 0.8)' : 'rgba(118, 75, 162, 0.8)'),
                    borderColor: revenueData.map((_, i) => i % 2 === 0 ? 'rgb(102, 126, 234)' : 'rgb(118, 75, 162)'),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return 'Rp ' + context.parsed.y + 'M';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'Rp ' + value + 'M';
                            }
                        }
                    }
                }
            }
        });
    </script>
}
