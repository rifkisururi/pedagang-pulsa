@model PedagangPulsa.Web.Areas.Admin.ViewModels.AdjustBalanceViewModel

<div class="modal-header bg-primary text-white">
    <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Adjust User Balance</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    <div class="alert alert-info">
        <div class="row">
            <div class="col-sm-4"><strong>Username:</strong></div>
            <div class="col-sm-8">@Model.Username</div>
        </div>
        @if (!string.IsNullOrEmpty(Model.FullName))
        {
            <div class="row">
                <div class="col-sm-4"><strong>Full Name:</strong></div>
                <div class="col-sm-8">@Model.FullName</div>
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.Email))
        {
            <div class="row">
                <div class="col-sm-4"><strong>Email:</strong></div>
                <div class="col-sm-8">@Model.Email</div>
            </div>
        }
        <div class="row">
            <div class="col-sm-4"><strong>Current Balance:</strong></div>
            <div class="col-sm-8">Rp @Model.CurrentBalance.ToString("N0")</div>
        </div>
    </div>

    <form asp-action="AdjustBalance" asp-controller="Balance" method="post" id="adjustBalanceFormInline">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="UserId" />

        <div class="mb-3">
            <label asp-for="Amount" class="form-label fw-bold">Amount <span class="text-danger">*</span></label>
            <div class="input-group">
                <span class="input-group-text">Rp</span>
                <input asp-for="Amount" class="form-control" required placeholder="Positive to add, negative to deduct" step="0.01" />
            </div>
            <span asp-validation-for="Amount" class="text-danger"></span>
            <small class="form-text text-muted">
                <i class="bi bi-info-circle"></i>
                Use <strong>positive</strong> value to add balance, <strong>negative</strong> to deduct
            </small>
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label">Admin Notes</label>
            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Reason for this adjustment..."></textarea>
        </div>

        <div class="alert alert-warning" id="warningMessage" style="display: none;">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Warning:</strong> This will <span id="actionType"></span> the user's balance and cannot be undone.
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-primary" onclick="submitAdjustBalance()">
        <i class="bi bi-check-circle"></i> Adjust Balance
    </button>
</div>

<script>
    function  'Rp '.+toLocaleString('id-ID') {
        return 'Rp ' + amount.toLocaleString('id-ID');
    }

    $('#Amount').on('input', function() {
        var amount = parseFloat($(this).val());
        var warningMsg = $('#warningMessage');
        var actionType = $('#actionType');

        if (!isNaN(amount) && amount !== 0) {
            warningMsg.show();
            if (amount > 0) {
                warningMsg.removeClass('alert-danger').addClass('alert-warning');
                actionType.html('<strong>add to</strong>');
            } else {
                warningMsg.removeClass('alert-warning').addClass('alert-danger');
                actionType.html('<strong>deduct from</strong>');
            }
        } else {
            warningMsg.hide();
        }
    });

    function submitAdjustBalance() {
        var form = $('#adjustBalanceFormInline');
        var amount = parseFloat($('#Amount').val());

        if (isNaN(amount) || amount === 0) {
            toastr.error('Please enter a valid non-zero amount');
            return;
        }

        $.ajax({
            url: form.attr('action'),
            type: 'POST',
            data: form.serialize(),
            success: function(response) {
                if (response.success) {
                    $('#adjustBalanceModalInline').modal('hide');
                    $('#balanceTable').DataTable().ajax.reload();
                    toastr.success(response.message);
                } else {
                    toastr.error(response.message);
                }
            },
            error: function() {
                toastr.error('An error occurred while processing your request.');
            }
        });
    }
</script>
