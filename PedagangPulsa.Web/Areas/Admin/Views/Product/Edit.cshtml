@model PedagangPulsa.Web.Areas.Admin.ViewModels.ProductViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Edit Product</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Details
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <h5 class="mb-3">Basic Information</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label">Product Code <span class="text-danger">*</span></label>
                            <input asp-for="Code" class="form-control" required />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Sku" class="form-label">SKU</label>
                            <input asp-for="Sku" class="form-control" />
                            <span asp-validation-for="Sku" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Name" class="form-label">Product Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">Category <span class="text-danger">*</span></label>
                            <select asp-for="CategoryId" class="form-select" required>
                                <option value="">-- Select Category --</option>
                                @if (Model.AvailableCategories != null)
                                {
                                    @foreach (var cat in Model.AvailableCategories)
                                    {
                                        <option value="@cat.Id" selected="@(Model.CategoryId == cat.Id)">@cat.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="SortOrder" class="form-label">Sort Order</label>
                            <input asp-for="SortOrder" class="form-control" type="number" />
                            <span asp-validation-for="SortOrder" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Description</label>
                            <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">Pricing</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label">Base Price <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" required />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CostPrice" class="form-label">Cost Price <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="CostPrice" class="form-control" type="number" step="0.01" min="0" required id="costPriceInput" />
                            </div>
                            <span asp-validation-for="CostPrice" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">Price per Level</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-striped" id="levelPricesTable">
                            <thead>
                                <tr>
                                    <th>Level</th>
                                    <th>Sell Price</th>
                                    <th>Margin</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.AvailableLevels != null && Model.LevelPrices != null)
                                {
                                    @for (int i = 0; i < Model.AvailableLevels.Count; i++)
                                    {
                                        var levelPrice = Model.LevelPrices.FirstOrDefault(lp => lp.LevelId == Model.AvailableLevels[i].Id);
                                        <tr>
                                            <td>
                                                <span class="badge bg-primary">@Model.AvailableLevels[i].Name</span>
                                                <input type="hidden" name="LevelPrices[@i].LevelId" value="@Model.AvailableLevels[i].Id" />
                                            </td>
                                            <td>
                                                <input type="number" name="LevelPrices[@i].SellPrice" class="form-control form-control-sm level-price-input"
                                                       step="0.01" min="0" value="@(levelPrice?.SellPrice ?? Model.Price)" data-level="@Model.AvailableLevels[i].Name" />
                                            </td>
                                            <td>
                                                <span class="margin-display">-</span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            Set sell price for each user level. If left empty, base price will be used.
                        </small>
                    </div>

                    <h5 class="mb-3">Settings</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                                <label asp-for="IsAvailable" class="form-check-label">Available for Purchase</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Update Product
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function calculateMargins() {
                const costPrice = parseFloat($('#costPriceInput').val()) || 0;

                $('.level-price-input').each(function() {
                    const sellPrice = parseFloat($(this).val()) || 0;
                    const margin = sellPrice - costPrice;
                    const marginRow = $(this).closest('tr').find('.margin-display');

                    marginRow.text('Rp ' + margin.toLocaleString('id-ID'));
                    marginRow.removeClass('text-danger text-success');
                    if (margin < 0) {
                        marginRow.addClass('text-danger');
                    } else if (margin > 0) {
                        marginRow.addClass('text-success');
                    }
                });
            }

            $('#costPriceInput').on('input', calculateMargins);
            $('.level-price-input').on('input', calculateMargins);

            // Initial calculation
            calculateMargins();
        });
    </script>
}
