@model PedagangPulsa.Web.Areas.Admin.ViewModels.UserLevelViewModel

@{
    ViewData["Title"] = "Edit User Level";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Edit User Level</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Details
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Level Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MarkupType" class="form-label">Markup Type <span class="text-danger">*</span></label>
                        <select asp-for="MarkupType" class="form-select" required>
                            <option value="">-- Select Markup Type --</option>
                            <option value="Percentage" selected="@(Model.MarkupType.ToString() == "Percentage")">Percentage</option>
                            <option value="Fixed" selected="@(Model.MarkupType.ToString() == "Fixed")">Fixed Amount</option>
                        </select>
                        <span asp-validation-for="MarkupType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MarkupValue" class="form-label">Markup Value <span class="text-danger">*</span></label>
                        <input asp-for="MarkupValue" class="form-control" type="number" step="0.01" min="0" required id="markupValueInput" />
                        <div class="form-text">
                            <i class="bi bi-info-circle"></i>
                            <span id="markupValueHelp">Enter markup percentage (e.g., 5 for 5%) or fixed amount</span>
                        </div>
                        <span asp-validation-for="MarkupValue" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Update Level
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            function updateMarkupHelp() {
                const markupType = $('#MarkupType').val();
                const markupValueHelp = $('#markupValueHelp');

                if (markupType === 'Percentage') {
                    markupValueHelp.text('Enter markup percentage (e.g., 5 for 5%)');
                } else if (markupType === 'Fixed') {
                    markupValueHelp.text('Enter fixed markup amount in Rupiah');
                } else {
                    markupValueHelp.text('Enter markup percentage or fixed amount');
                }
            }

            $('#MarkupType').on('change', updateMarkupHelp);

            // Initial call
            updateMarkupHelp();
        });
    </script>
}
