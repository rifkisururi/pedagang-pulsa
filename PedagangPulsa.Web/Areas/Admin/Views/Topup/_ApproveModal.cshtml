@model PedagangPulsa.Web.Areas.Admin.ViewModels.ApproveTopupViewModel

<div class="modal-header bg-success text-white">
    <h5 class="modal-title"><i class="bi bi-check-circle"></i> Approve Topup Request</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>
<div class="modal-body">
    <form asp-action="Approve" asp-controller="Topup" asp-area="Admin" method="post" id="approveForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="alert alert-info">
            <div class="row">
                <div class="col-sm-4"><strong>Username:</strong></div>
                <div class="col-sm-8">@Model.Username</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.FullName))
            {
                <div class="row">
                    <div class="col-sm-4"><strong>Full Name:</strong></div>
                    <div class="col-sm-8">@Model.FullName</div>
                </div>
            }
            <div class="row">
                <div class="col-sm-4"><strong>Bank:</strong></div>
                <div class="col-sm-8">@Model.BankName</div>
            </div>
            <div class="row">
                <div class="col-sm-4"><strong>Requested Amount:</strong></div>
                <div class="col-sm-8">Rp @Model.Amount.ToString("N0")</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.TransferProof))
        {
            <div class="mb-3 text-center">
                <label class="form-label fw-bold">Transfer Proof</label><br />
                <a href="@Model.TransferProof" target="_blank" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-image"></i> View Transfer Proof
                </a>
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Current Balance</label>
            <input type="text" class="form-control" value="Rp @Model.CurrentBalance.ToString("N0")" readonly />
        </div>

        <div class="mb-3">
            <label asp-for="FinalAmount" class="form-label fw-bold">Final Amount to Add</label>
            <div class="input-group">
                <span class="input-group-text">Rp</span>
                <input asp-for="FinalAmount" class="form-control" />
            </div>
            <span asp-validation-for="FinalAmount" class="text-danger"></span>
            <small class="form-text text-muted">
                Final balance will be: <strong id="finalBalance">Rp @(Model.CurrentBalance + Model.FinalAmount).ToString("N0")</strong>
            </small>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="mb-3">
                <label class="form-label">User Notes</label>
                <textarea class="form-control" readonly>@Model.Notes</textarea>
            </div>
        }

        <div class="mb-3">
            <label asp-for="Notes" class="form-label">Admin Notes (Optional)</label>
            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Add notes for this approval..."></textarea>
        </div>

        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Warning:</strong> This action will add the final amount to the user's balance and cannot be undone.
        </div>
    </form>
</div>
<div class="modal-footer">
    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
    <button type="button" class="btn btn-success" onclick="submitApproveForm()">
        <i class="bi bi-check-circle"></i> Approve
    </button>
</div>

<script>
    function  'Rp '.+toLocaleString('id-ID') {
        return 'Rp ' + amount.toLocaleString('id-ID');
    }

    // Update final balance when final amount changes
    $('#FinalAmount').on('input', function() {
        const currentBalance = @Model.CurrentBalance;
        const finalAmount = parseFloat($(this).val()) || 0;
        const total = currentBalance + finalAmount;
        $('#finalBalance').text('Rp ' + total.toLocaleString('id-ID'));
    });

    function submitApproveForm() {
        const form = $('#approveForm');
        $.ajax({
            url: form.attr('action'),
            type: 'POST',
            data: form.serialize(),
            success: function(response) {
                if (response.success) {
                    $('#approveModal').modal('hide');
                    $('#topupTable').DataTable().ajax.reload();
                    toastr.success(response.message);
                } else {
                    toastr.error(response.message);
                }
            },
            error: function() {
                toastr.error('An error occurred while processing your request.');
            }
        });
    }
</script>
