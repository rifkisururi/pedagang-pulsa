@model PedagangPulsa.Web.Areas.Admin.ViewModels.SupplierViewModel

@{
    ViewData["Title"] = "Create Supplier";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Create Supplier</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <h5 class="mb-3">Basic Information</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Supplier Name <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g., Digiflazz" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TimeoutSeconds" class="form-label">Timeout (seconds) <span class="text-danger">*</span></label>
                            <input asp-for="TimeoutSeconds" class="form-control" type="number" min="10" max="120" value="30" required />
                            <span asp-validation-for="TimeoutSeconds" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">API Configuration</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-12">
                            <label asp-for="ApiUrl" class="form-label">API URL <span class="text-danger">*</span></label>
                            <input asp-for="ApiUrl" class="form-control" placeholder="https://api.example.com" type="url" required />
                            <span asp-validation-for="ApiUrl" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ApiKey" class="form-label">API Key <span class="text-danger">*</span></label>
                            <input asp-for="ApiKey" class="form-control" type="password" required />
                            <div class="form-text">This will be encrypted before storing</div>
                            <span asp-validation-for="ApiKey" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ApiSecret" class="form-label">API Secret</label>
                            <input asp-for="ApiSecret" class="form-control" type="password" />
                            <div class="form-text">Optional, only if required by supplier</div>
                            <span asp-validation-for="ApiSecret" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">Balance Configuration</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="InitialBalance" class="form-label">Initial Balance <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="InitialBalance" class="form-control" type="number" step="0.01" min="0" value="0" required />
                            </div>
                            <span asp-validation-for="InitialBalance" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BalanceThresholdLow" class="form-label">Low Threshold</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="BalanceThresholdLow" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <div class="form-text">Warning when balance falls below this</div>
                            <span asp-validation-for="BalanceThresholdLow" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="BalanceThresholdCritical" class="form-label">Critical Threshold</label>
                            <div class="input-group">
                                <span class="input-group-text">Rp</span>
                                <input asp-for="BalanceThresholdCritical" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <div class="form-text">Critical alert when balance falls below this</div>
                            <span asp-validation-for="BalanceThresholdCritical" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="mb-3">Settings</h5>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="form-check form-switch">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="IsActive" class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> Create Supplier
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
